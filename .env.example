# Twilio (required for placing calls)
# Get from https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# A Twilio phone number (Voice-capable) to call FROM
TWILIO_PHONE_NUMBER=

# Base URL of your server (must be HTTPS for Twilio, use ngrok in dev)
# Example: https://abc123.ngrok.io  (no trailing slash)
DOMAIN = 

# OpenAI (for Whisper STT and TTS)
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Test number from the challenge (do not change unless instructed)
TEST_NUMBER=+18054398008


